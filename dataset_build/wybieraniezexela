import re
from pathlib import Path
from typing import Optional, Tuple, List
from datetime import datetime
import pandas as pd
import os


EXCEL_PATH = r"C:\Users\danil\.vscode\grafy\dataset\100_results_run-2.xlsx"
OUT_ROOT = Path(r"C:\Users\danil\.vscode\grafy\dataset\grafyzexela")

TOPO_RE = re.compile(r"t(\d+_\d+)")
FLOAT_RE = re.compile(r"[-+]?(?:\d+\.\d+|\d+\.|\.\d+|\d+)(?:[eE][-+]?\d+)?")

SKIPPED_LOG_PATH = r"C:\Users\danil\.vscode\grafy\dataset\grafyzexela\skipped_rows.txt"


def parse_graph_type_from_text(text: str) -> Optional[str]:
    if not text:
        return None
    m = TOPO_RE.search(text)
    return m.group(1) if m else None


def parse_arc_points(text: str) -> list[tuple[float, float, float]]:
    nums = [float(x) for x in FLOAT_RE.findall(text)]
    if not nums:
        return []
    if len(nums) % 3 != 0:
        raise ValueError(f"Arc: liczby={len(nums)} nie dzielą się przez 3. Początek: {text[:120]!r}")
    return [(nums[i], nums[i + 1], nums[i + 2]) for i in range(0, len(nums), 3)]


def write_xyz(out_path: Path, arcs: list[list[tuple[float, float, float]]]) -> None:
    out_path.parent.mkdir(parents=True, exist_ok=True)
    with out_path.open("w", encoding="utf-8") as f:
        for edge_id, pts in enumerate(arcs):
            for i, (x, y, z) in enumerate(pts):
                f.write(f"{edge_id} {i} {x} {y} {z}\n")


def row_to_text(row) -> str:
    """
    Łączy wszystkie komórki w wierszu w jeden string (odporne na brak kolumn).
    """
    parts = []
    for v in row:
        if v is None:
            continue
        if isinstance(v, float) and pd.isna(v):
            continue
        s = str(v).strip()
        if s:
            parts.append(s)
    return " ".join(parts)


def extract_arcs_from_row_text(row_text: str) -> Optional[Tuple[str, List[str]]]:
    gtype = parse_graph_type_from_text(row_text)
    if gtype is None:
        return None

    segs = [s.strip() for s in row_text.split("|") if s.strip()]

    arc_candidates = []
    for s in segs:
        # heurystyka: łuk = bardzo dużo liczb (punkty 3D), zwykle z przecinkami
        nums = FLOAT_RE.findall(s)
        if len(nums) >= 60 and "," in s:
            arc_candidates.append(s)

    if len(arc_candidates) < 3:
        return None

    return gtype, arc_candidates[-3:]


def log_skipped_row(log_path: str, reason: str, row_idx: int, row_text: str) -> None:
    # Czyścimy nowe linie i taby, żeby faktycznie było 1-linijkowo.
    compact = " ".join(str(row_text).replace("\t", " ").split())
    ts = datetime.now().strftime("%Y-%m-%d %H:%M:%S")
    line = f"[{ts}] row={row_idx} reason={reason} | {compact}\n"
    with open(log_path, "a", encoding="utf-8") as f:
        f.write(line)


def reset_log_file(log_path: str) -> None:
    os.makedirs(os.path.dirname(log_path), exist_ok=True)
    with open(log_path, "w", encoding="utf-8") as f:
        f.write("# Skipped rows log\n")



